<div class="form-container">
  <div class="form-card">
    <!-- Header -->
    <div class="form-header">
      <div class="header-left">
        <i class="bi" [ngClass]="id ? 'bi-pencil-square' : 'bi-plus-circle'"></i>
        <div>
          <h2>{{ id ? 'Edit Service' : 'Add New Service' }}</h2>
          <p>{{ id ? 'Update existing service details' : 'Create a new automotive service' }}</p>
        </div>
      </div>
    </div>

    <!-- Form -->
    <form [formGroup]="form" (ngSubmit)="submit()">
      
      <!-- Row 1: Service Name & Category -->
      <div class="form-row">
        <div class="form-group">
          <label>Service Name *</label>
          <input type="text" formControlName="name" placeholder="Enter service name" class="form-control">
          <small class="error" *ngIf="form.get('name')?.invalid && form.get('name')?.touched">Service name is required</small>
        </div>

        <div class="form-group">
          <label>Category *</label>
          <div class="custom-select-wrapper">
            <select formControlName="category" class="form-control custom-select">
              <option value="" disabled>Select category</option>
              <option value="Oil Change">🔧 Oil Change</option>
              <option value="Repair">⚙️ Repair</option>
              <option value="Inspection">🔍 Inspection</option>
              <option value="Maintenance">🛠️ Maintenance</option>
              <option value="Detailing">🧼 Detailing</option>
            </select>
            <i class="bi bi-chevron-down dropdown-icon"></i>
          </div>
          <small class="error" *ngIf="form.get('category')?.invalid && form.get('category')?.touched">Category is required</small>
        </div>
      </div>

      <!-- Row 2: Brand & Model -->
      <div class="form-row">
        <div class="form-group">
          <label>Brand *</label>
          <input type="text" formControlName="brand" placeholder="e.g., Toyota, Honda, BMW" class="form-control">
          <small class="error" *ngIf="form.get('brand')?.invalid && form.get('brand')?.touched">Brand is required</small>
        </div>

        <div class="form-group">
          <label>Model *</label>
          <input type="text" formControlName="model" placeholder="e.g., Camry, Civic, X5" class="form-control">
          <small class="error" *ngIf="form.get('model')?.invalid && form.get('model')?.touched">Model is required</small>
        </div>
      </div>

      <!-- Row 3: Year & Duration -->
      <div class="form-row">
        <div class="form-group">
          <label>Year *</label>
          <input type="number" formControlName="year" placeholder="e.g., 2024" class="form-control">
          <small class="error" *ngIf="form.get('year')?.invalid && form.get('year')?.touched">Enter valid year (1900-2026)</small>
        </div>

        <div class="form-group">
          <label>Duration (minutes) *</label>
          <input type="number" formControlName="duration" placeholder="e.g., 60" class="form-control">
          <small class="error" *ngIf="form.get('duration')?.invalid && form.get('duration')?.touched">Minimum 15 minutes required</small>
        </div>
      </div>

      <!-- Row 4: Base Price & Tax -->
      <div class="form-row">
        <div class="form-group">
          <label>Base Price (₹) *</label>
          <input type="number" formControlName="basePrice" placeholder="0" class="form-control">
          <small class="error" *ngIf="form.get('basePrice')?.invalid && form.get('basePrice')?.touched">Price must be greater than 0</small>
        </div>

        <div class="form-group">
          <label>Tax Percentage (%) *</label>
          <input type="number" formControlName="taxPercentage" placeholder="e.g., 18" class="form-control">
          <small class="error" *ngIf="form.get('taxPercentage')?.invalid && form.get('taxPercentage')?.touched">Tax between 0-100%</small>
        </div>
      </div>

      <!-- Row 5: Discount -->
      <div class="form-row">
        <div class="form-group full-width">
          <label>Discount (%)</label>
          <input type="number" formControlName="discount" placeholder="0" class="form-control">
          <small class="error" *ngIf="form.get('discount')?.invalid && form.get('discount')?.touched">Discount between 0-100%</small>
        </div>
      </div>

      <!-- Price Preview -->
      <div class="price-preview">
        <div class="price-label">Final Price</div>
        <div class="price-amount">₹ {{ previewPrice() }}</div>
        <div class="price-breakdown">
          <span>Base: ₹{{ form.get('basePrice')?.value || 0 }}</span>
          <span *ngIf="form.get('taxPercentage')?.value"> + Tax: ₹{{ calculateTax() }}</span>
          <span *ngIf="form.get('discount')?.value" class="discount-text"> - Discount: ₹{{ calculateDiscount() }}</span>
        </div>
      </div>

      <!-- Buttons -->
      <div class="form-buttons">
        <button type="button" class="btn btn-secondary" routerLink="/catalog">Cancel</button>
        <button type="submit" class="btn btn-primary" [disabled]="form.invalid">
          <i class="bi" [ngClass]="id ? 'bi-pencil' : 'bi-save'"></i>
          {{ id ? 'Update Service' : 'Save Service' }}
        </button>
      </div>
    </form>
  </div>
</div>

* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}

.form-container {
  min-height: 100vh;
  background: #f5f7fa;
  padding: 40px 24px;
  display: flex;
  justify-content: center;
  align-items: center;
}

.form-card {
  max-width: 900px;
  width: 100%;
  background: white;
  border-radius: 20px;
  box-shadow: 0 10px 40px rgba(0, 0, 0, 0.08);
  overflow: hidden;
}

/* Header */
.form-header {
  padding: 32px 40px;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.header-left {
  display: flex;
  align-items: center;
  gap: 16px;
}

.header-left i {
  font-size: 2.5rem;
  color: white;
  background: rgba(255, 255, 255, 0.2);
  padding: 12px;
  border-radius: 16px;
}

.header-left h2 {
  color: white;
  font-size: 1.8rem;
  font-weight: 600;
  margin: 0 0 4px 0;
}

.header-left p {
  color: rgba(255, 255, 255, 0.9);
  font-size: 0.9rem;
  margin: 0;
}

/* Form */
form {
  padding: 32px 40px 40px 40px;
}

.form-row {
  display: flex;
  gap: 24px;
  margin-bottom: 24px;
}

.form-group {
  flex: 1;
  display: flex;
  flex-direction: column;
  position: relative;
}

.form-group.full-width {
  flex: 100%;
}

label {
  font-size: 0.85rem;
  font-weight: 600;
  color: #333;
  margin-bottom: 8px;
  letter-spacing: 0.3px;
}

.form-control {
  padding: 12px 16px;
  font-size: 0.95rem;
  border: 1.5px solid #e0e4e8;
  border-radius: 12px;
  transition: all 0.2s;
  outline: none;
  font-family: inherit;
  width: 100%;
}

.form-control:focus {
  border-color: #667eea;
  box-shadow: 0 0 0 3px rgba(102, 126, 234, 0.1);
}

.form-control.ng-invalid.ng-touched {
  border-color: #dc3545;
}

/* Custom Select Wrapper - Fixes dropdown positioning */
.custom-select-wrapper {
  position: relative;
  width: 100%;
}

.custom-select {
  appearance: none;
  -webkit-appearance: none;
  -moz-appearance: none;
  cursor: pointer;
  background: white;
  padding-right: 40px;
}

.dropdown-icon {
  position: absolute;
  right: 14px;
  top: 50%;
  transform: translateY(-50%);
  pointer-events: none;
  color: #667eea;
  font-size: 1rem;
}

/* Ensure dropdown options appear correctly */
select.form-control option {
  padding: 10px;
  background: white;
  color: #333;
}

/* For better dropdown visibility on all browsers */
select.form-control optgroup,
select.form-control option {
  font-size: 0.9rem;
}

/* Fix for number inputs - remove spinner arrows */
input[type="number"] {
  -moz-appearance: textfield;
}

input[type="number"]::-webkit-inner-spin-button,
input[type="number"]::-webkit-outer-spin-button {
  -webkit-appearance: none;
  margin: 0;
}

.error {
  color: #dc3545;
  font-size: 0.7rem;
  margin-top: 6px;
  display: block;
}

/* Price Preview */
.price-preview {
  background: linear-gradient(135deg, #f8f9ff 0%, #f0f2ff 100%);
  border-radius: 16px;
  padding: 20px 24px;
  margin: 28px 0 32px 0;
  border: 1px solid #e0e4ff;
  text-align: center;
}

.price-label {
  font-size: 0.85rem;
  text-transform: uppercase;
  letter-spacing: 1px;
  color: #666;
  margin-bottom: 8px;
}

.price-amount {
  font-size: 2.5rem;
  font-weight: 800;
  color: #667eea;
  margin-bottom: 12px;
}

.price-breakdown {
  font-size: 0.8rem;
  color: #666;
  display: flex;
  justify-content: center;
  gap: 16px;
  flex-wrap: wrap;
}

.discount-text {
  color: #dc3545;
}

/* Buttons */
.form-buttons {
  display: flex;
  gap: 16px;
  justify-content: flex-end;
}

.btn {
  padding: 12px 28px;
  font-size: 0.9rem;
  font-weight: 600;
  border: none;
  border-radius: 40px;
  cursor: pointer;
  transition: all 0.2s;
  font-family: inherit;
  display: inline-flex;
  align-items: center;
  gap: 8px;
}

.btn-primary {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
}

.btn-primary:hover:not(:disabled) {
  transform: translateY(-2px);
  box-shadow: 0 6px 20px rgba(102, 126, 234, 0.4);
}

.btn-primary:disabled {
  opacity: 0.6;
  cursor: not-allowed;
}

.btn-secondary {
  background: white;
  color: #666;
  border: 1.5px solid #e0e4e8;
}

.btn-secondary:hover {
  background: #f8f9fa;
  border-color: #667eea;
}

/* Responsive */
@media (max-width: 768px) {
  .form-container {
    padding: 20px 16px;
  }

  .form-header {
    padding: 24px 20px;
  }

  form {
    padding: 24px 20px 32px 20px;
  }

  .form-row {
    flex-direction: column;
    gap: 20px;
    margin-bottom: 20px;
  }

  .header-left h2 {
    font-size: 1.4rem;
  }

  .header-left i {
    font-size: 1.8rem;
    padding: 10px;
  }

  .price-amount {
    font-size: 2rem;
  }

  .form-buttons {
    flex-direction: column;
  }

  .btn {
    justify-content: center;
  }
  
  .custom-select-wrapper {
    width: 100%;
  }
}
